# Zero Configuration
# =================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ======================
# REQUIRED
# ======================

# Security token for API authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
ZERO_GATEWAY_TOKEN=

# ======================
# OPTIONAL - Directory paths (defaults work for Docker)
# ======================

# ZERO_CONFIG_DIR=./config
# ZERO_WORKSPACE_DIR=./workspace

# ======================
# OPTIONAL - Integrations
# ======================

# Discord Bot
# Create app at: https://discord.com/developers/applications
# Go to Bot section, copy the token
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=
DISCORD_GUILD_ID=
DISCORD_NOTIFICATION_CHANNEL_ID=

# Slack Integration (Socket Mode)
# Create app at: https://api.slack.com/apps
# App-Level Token (xapp-...) - Settings > Socket Mode > Generate Token
SLACK_APP_TOKEN=
# Bot Token (xoxb-...) - OAuth & Permissions > Install to Workspace
SLACK_BOT_TOKEN=

# GitHub Personal Access Token (for private repo access)
# Create at: https://github.com/settings/tokens?type=beta
GH_TOKEN=

# Gmail & Google Calendar OAuth2 Configuration
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new project (or use existing)
# 2. Enable Gmail API & Google Calendar API: APIs & Services > Library
# 3. Create OAuth 2.0 Client ID: APIs & Services > Credentials > Create Credentials > OAuth client ID
# 4. Application type: Web application
# 5. Add redirect URI: http://localhost:18792/api/google/auth/callback
ZERO_GOOGLE_CLIENT_ID=
ZERO_GOOGLE_CLIENT_SECRET=
ZERO_GOOGLE_REDIRECT_URI=http://localhost:18792/api/google/auth/callback

# Frontend URL (for CORS and redirects after OAuth)
ZERO_FRONTEND_URL=http://localhost:5173

# Hugging Face (required for pyannote speaker diarization)
# HF_TOKEN=

# ======================
# OPTIONAL - Meeting Intelligence (DailyMemory)
# ======================

# Whisper transcription settings
# ZERO_WHISPER_MODEL_SIZE=large-v3
# ZERO_WHISPER_DEVICE=cuda
# ZERO_WHISPER_COMPUTE_TYPE=float16
# ZERO_WHISPER_LANGUAGE=en

# Recording settings
# ZERO_RECORDINGS_DIR=../workspace/recordings
# ZERO_AUDIO_SOURCE=mixed
# ZERO_SAMPLE_RATE=16000
# ZERO_AUTO_RECORD_MEETINGS=false

# Speaker diarization (requires HF_TOKEN above)
# ZERO_DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
# ZERO_MAX_SPEAKERS=10

# PostgreSQL (required for database)
# ZERO_POSTGRES_PASSWORD=zero_dev

# Multi-Provider LLM API Keys
# ZERO_KIMI_API_KEY=
# ZERO_KIMI_BASE_URL=https://api.moonshot.ai/v1
# ZERO_GEMINI_API_KEY=
# ZERO_OPENROUTER_API_KEY=
# ZERO_HUGGINGFACE_API_KEY=
# MiniMax M2.7 for character content final review (falls back to Kimi).
# Get API key at: https://platform.minimax.io
# ZERO_MINIMAX_API_KEY=
# ZERO_MINIMAX_BASE_URL=https://api.minimax.io/v1
# ZERO_LLM_DAILY_BUDGET_USD=5.0

# Free Image APIs (for character image sourcing)
# ZERO_PEXELS_API_KEY=
# ZERO_UNSPLASH_ACCESS_KEY=
# ZERO_PIXABAY_API_KEY=
